---
import Hero from '../sections/Hero.astro';
import '../fonts.css';
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-writing-dark">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Michael Banna is an Apple platform developer focused on building polished iOS and iPadOS products with SwiftUI, strong interaction design, and durable production UX."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script
      src="https://kit.fontawesome.com/335df166b2.js"
      crossorigin="anonymous"></script>
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="w-full neue-montreal">
    <Hero />
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-Regular.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-Bold.woff2') format('woff2');
    font-weight: bold;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-Book.woff2') format('woff2');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-Italic.woff2') format('woff2');
    font-weight: normal;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-Medium.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-Thin.woff2') format('woff2');
    font-weight: 100;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-ThinItalic.woff2') format('woff2');
    font-weight: 100;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Neue Montreal';
    src: url('/fonts/neue-montreal/PPNeueMontreal-BoldItalic.woff2') format('woff2');
    font-weight: bold;
    font-style: italic;
    font-display: swap;
  }

  :root {
    --accent: 86, 105, 129;
    --accent-gradient: linear-gradient(
      45deg,
      rgb(var(--accent)),
      #72a0c1 30%,
      white 60%
    );
  }
  html {
    font-family: 'Neue Montreal', system-ui, sans-serif;
    background-color: #f3f7fa;
    scroll-behavior: smooth;
  }
  body {
    font-family: 'Neue Montreal', system-ui, sans-serif;
  }
  code {
    font-family: Menlo, Monaco, Lucida Console, Liberation Mono,
      DejaVu Sans Mono, Bitstream Vera Sans Mono, Courier New, monospace;
  }
  .neue-montreal {
    font-family: 'Neue Montreal', system-ui, sans-serif;
  }
</style>
