---
const socialLinks = [
  {
    href: 'https://linkedin.com/in/michael-banna',
    label: 'connect with me on linkedin',
    icon: 'fa-linkedin',
  },
  {
    href: 'https://github.com/bmchl',
    label: 'browse my github',
    icon: 'fa-github',
  },
  {
    href: 'mailto:michael@banna.dev',
    label: 'send me an email',
    icon: 'fa-envelope',
  },
  {
    href: '/Michael_Banna_Resume.pdf',
    label: 'download my resume',
    icon: 'fa-file',
    target: '_blank',
    rel: 'noopener noreferrer',
  },
];
---

<div class="flex h-auto w-full flex-row justify-between content-center text-2xl">
  {
    socialLinks.map(({ href, label, icon, target, rel }) => (
      <a
        href={href}
        target={target}
        rel={rel}
        aria-label={label}
        class="group relative inline-flex items-center justify-center"
      >
        <i class={`fa ${icon} p-3 transition-all hover:text-primary`}></i>
        <span class="pointer-events-none absolute left-1/2 top-full z-20 mt-3 -translate-x-1/2 translate-y-1 whitespace-nowrap rounded-full bg-primary-dark px-3 py-1.5 text-xs font-medium text-writing-dark opacity-0 shadow-lg shadow-primary-dark/10 transition-all duration-200 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100">
          {label}
        </span>
      </a>
    ))
  }
</div>
